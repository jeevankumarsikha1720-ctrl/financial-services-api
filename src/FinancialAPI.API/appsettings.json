{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=financialdb;Username=financialuser;Password=StrongPassword@123;Pooling=true;MinPoolSize=5;MaxPoolSize=100;"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "financial-api-group",
    "SecurityProtocol": "PLAINTEXT",
    "Topics": {
      "PaymentEvents": "payment-events",
      "SettlementEvents": "settlement-events",
      "BeneficiaryEvents": "beneficiary-events",
      "LedgerEvents": "ledger-events",
      "FraudAlerts": "fraud-alerts",
      "NotificationEvents": "notification-events"
    }
  },
  "JwtSettings": {
    "Secret": "SuperSecretKey_ChangeInProduction_Min32Chars!",
    "Issuer": "FinancialAPI",
    "Audience": "FinancialAPIClients",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/financial-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
